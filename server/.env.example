# AURA server environment variables — copy to server/.env and fill in.

PORT=5000
MONGO_URI=<mongodb connection string>
JWT_SECRET=<random secret used to sign auth + EMR access tokens>
GEMINI_API_KEY=<google gemini api key>

# PHI field-encryption key for the patient medical record (EMR).
# Must be a base64-encoded 32-byte value. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WARNING: keep this secret and back it up separately from the database.
# Losing it makes all encrypted medical records unrecoverable.
EMR_ENCRYPTION_KEY=<base64 32-byte key>
